# -----------------------------------------------------------------------
# Install map
# -----------------------------------------------------------------------
[installmap@ghactions-installs]
path_root=INSTALL_ROOT
path_python-lib=PYTHON
owner_root=root
group_root=root

map_CsmakeModules=
   map: <CsmakeModules> -(1-1)-> {PYTHON}/CsmakeGHActions/CsmakeModules/[~~file~~]
   copyright: ghactions-copyright
   owner:{root}
   group:{root}
   permissions:644

map_GHActionsLibrary=
   map: <GHActionsLibrary> -(1-1)-> {PYTHON}/GHActionsLibrary/[~~file~~]
   copyright: ghactions-copyright
   owner:{root}
   group:{root}
   permissions:644

# -----------------------------------------------------------------------
# Versioning
# -----------------------------------------------------------------------
[versioning@snapshot-version]
designation=snapshot
format={datetime}.{gitSHA}
shell_datetime=date --utc +%%Y%%m%%d%%H%%M%%S
shell_gitSHA=git rev-parse HEAD

[versioning@rc-version]
designation=rc
format=rc{rc}
value_rc=1

# -----------------------------------------------------------------------
# Package targets
# -----------------------------------------------------------------------
[WheelPackage@wheel-ghactions]
package-version=1.0
top-level=CsmakeGHActions
maps=ghactions-installs
result=%(RESULTS)s/wheelfile

[ZipPackager@zip-ghactions]
package-version=1.0
maps=ghactions-installs
result=%(RESULTS)s/zipfile

[CsmakeModulePackager@csm-ghactions]
result=%(RESULTS)s/csm
include=
    CsmakeModules/*.py,
    GHActionsLibrary/*.py
dependencies=
    csmake-node-runtime>=1.0.0,
    csmake-docker-runtime>=1.0.0

# -----------------------------------------------------------------------
# Integration tests
# -----------------------------------------------------------------------
[GHActions@hello-default]
--action=./test-actions/hello-composite

[GHActions@hello-named]
--action=./test-actions/hello-composite
who-to-greet=csmake

[command@test-ghactions]
description=Run integration tests against local composite actions
0000=hello-default
0010=hello-named

[~~test~~]
00=test-ghactions

# -----------------------------------------------------------------------
# Build commands
# -----------------------------------------------------------------------
[command@default]
description=Create and package a csmake-ghactions release
00=csmake-ghactions, wheel-ghactions & zip-ghactions & csm-ghactions

[command@wheel-only]
description=Create a wheel package only
00=csmake-ghactions, wheel-ghactions

[command@zip-only]
description=Create a zip package only
00=csmake-ghactions, zip-ghactions

[command@snapshot]
description=Build a snapshot package
00=csmake-ghactions, snapshot-version, default

[command@rc]
description=Build a release candidate package
00=csmake-ghactions, rc-version, default
