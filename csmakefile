[~~phases~~]
clean=Remove all csmake generated files
package=Create the csmake-ghactions package
test=Run unit and integration tests
**sequences=
   clean -> package: build the csmake-ghactions install package
**default=clean -> package

# -----------------------------------------------------------------------
# Package metadata
# -----------------------------------------------------------------------
[metadata@csmake-ghactions]
name=csmake-ghactions
version=1.0.0
description=GitHub Actions workflow and action execution for csmake
about=Provides csmake modules and an extension for running GitHub Actions
 locally as part of a csmake build.
 .
 Modules:
   GHActions      - execute any GitHub Action (composite, node, or docker)
   GHActionsShell - execute a GHA 'run:' step with full GHA protocol
 .
 Extension:
   Extension__GHActions - registers --gha-workflow so csmake can execute
                          a GitHub Actions workflow YAML directly in place
                          of a csmakefile.
 .
 Library:
   GHActionsLibrary - YAML workflow parser (GHActionsFileReader)
 .
 Requires csmake-node-runtime and csmake-docker-runtime on PYTHONPATH
 for Node.js and Docker action execution respectively.
packager=Autumn Patterson <autumn@devops-csmake.com>
manufacturer=devops-csmake
depends=python3, csmake, csmake-node-runtime, csmake-docker-runtime, python3-yaml
keywords=make build development github actions ci workflow
url=https://github.com/devops-csmake/csmake-ghactions
copyrights=ghactions-copyright
classifiers=
    Development Status :: 4 - Beta
    Intended Audience :: Developers
    Topic :: Software Development :: Build Tools
    Programming Language :: Python :: 3
    License :: OSI Approved :: GNU General Public License v3 (GPLv3)
**files=
    <CsmakeModules (python:csmake-modules)> CsmakeModules/*.py,
    <GHActionsLibrary (python:library)> GHActionsLibrary/*.py

